{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "VisualEditor0",
			"Effect": "Allow",
			"Action": [
				"acm:ImportCertificate",
				"cloudfront:GetDistribution",
				"cloudfront:GetDistributionConfig",
				"cloudfront:CreateDistribution",
				"cloudfront:UpdateDistribution",
				"cloudfront:ListDistributions"
			],
			"Resource": "*"
		},
		{
			"Sid": "VisualEditor1",
			"Effect": "Allow",
			"Action": "s3:*",
			"Resource": [
				"arn:aws:s3:::www.example.com",
				"arn:aws:s3:::www.example.com/*"
			]
		}
	]
}
